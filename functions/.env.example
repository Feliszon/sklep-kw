# Skopiuj ten plik do functions/.env i uzupełnij prawdziwymi danymi.
# functions/.env NIE jest commitowany (patrz .gitignore).

# Środowisko P24: sandbox | production
P24_ENV=sandbox

# Dane sprzedawcy z panelu P24 (Ustawienia sklepu > Dane techniczne).
# UWAGA: konto sandbox (sandbox.przelewy24.pl) i konto produkcyjne (secure.przelewy24.pl)
# to dwa oddzielne konta - każde ma własny komplet poniższych wartości.
P24_MERCHANT_ID=
P24_POS_ID=

# Klucz API (do Basic Auth w REST API) - panel P24 > Klucze do raportów / Klucze API
P24_API_KEY=

# Klucz CRC (do liczenia/weryfikacji pola "sign") - panel P24 > Klucze CRC
P24_CRC_KEY=

# Publiczny adres frontendu - używany do budowy urlReturn (powrót klienta z P24).
# To NIE musi być publicznie dostępne z internetu - przeglądarka klienta i tak
# jest już "u siebie", więc lokalnie może to być zwykły http://localhost:3000.
FRONTEND_URL=http://localhost:3000

# Publiczny adres funkcji paymentWebhook - MUSI być osiągalny z internetu,
# bo to na ten adres serwery P24 wysyłają powiadomienie o statusie płatności.
# Lokalnie: adres tunelu ngrok wskazujący na emulator Functions, np.
# https://xxxx.ngrok-free.app/<project-id>/europe-west1/paymentWebhook
# Po wdrożeniu: URL zwrócony przez `firebase deploy --only functions`.
P24_WEBHOOK_URL=
